---
// Netlify Forms: data-netlify="true" + hidden form-name field
---
<section id="contact" class="band band--green">
  <div class="wrap contact-grid">
    <div class="contact-left">
      <span class="section-label" style="color:rgba(243,239,228,.5)">006 — Get in Touch</span>
      <h2 class="contact-hl t-display reveal">Let's<br/>build<br/>together.</h2>
      <p class="contact-sub reveal">
        Open to freelance work, full-time roles,<br/>
        and interesting side projects.
      </p>
      <a href="mailto:afsin@example.com" class="contact-email t-mono reveal">
        afsin@example.com&nbsp;↗
      </a>
    </div>

    <div class="contact-right reveal">
      <form name="contact" method="POST" data-netlify="true" class="contact-form">
        <input type="hidden" name="form-name" value="contact" />
        <div class="form-field">
          <label class="t-mono" for="cf-name">Name</label>
          <input type="text" id="cf-name" name="name" required
            placeholder="Your name" autocomplete="name" />
        </div>
        <div class="form-field">
          <label class="t-mono" for="cf-email">Email</label>
          <input type="email" id="cf-email" name="email" required
            placeholder="your@email.com" autocomplete="email" />
        </div>
        <div class="form-field">
          <label class="t-mono" for="cf-msg">Message</label>
          <textarea id="cf-msg" name="message" rows="5" required
            placeholder="Tell me about your project…"></textarea>
        </div>
        <button type="submit" class="t-mono contact-submit">
          Send message →
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 6rem; align-items: start;
  }
  .contact-hl {
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: .84; color: var(--paper);
    margin: 1rem 0 1.5rem;
  }
  .contact-sub {
    font-family: 'Outfit', sans-serif;
    font-size: .82rem; color: rgba(243,239,228,.6);
    line-height: 1.7; margin-bottom: 2rem;
  }
  .contact-email {
    font-size: .78rem; letter-spacing: .1em;
    color: var(--paper); text-decoration: none;
    border-bottom: 1px solid rgba(243,239,228,.35);
    padding-bottom: .2rem;
    transition: border-color .3s ease;
  }
  .contact-email:hover { border-color: var(--paper); }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .form-field { display: flex; flex-direction: column; gap: .5rem; }
  .form-field label {
    font-size: .62rem; letter-spacing: .15em; text-transform: uppercase;
    color: rgba(243,239,228,.45);
  }
  .form-field input,
  .form-field textarea {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.14);
    color: var(--paper); padding: .9rem 1rem;
    font-family: 'Outfit', sans-serif; font-size: .9rem;
    outline: none; resize: vertical;
    transition: border-color .3s ease;
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: rgba(243,239,228,.22);
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-color: rgba(61,139,101,.8);
  }
  .contact-submit {
    align-self: flex-start;
    background: var(--paper); color: var(--m);
    border: none; padding: .95rem 2rem;
    font-size: .72rem; letter-spacing: .15em; text-transform: uppercase;
    cursor: pointer;
    transition: background .3s ease, color .3s ease;
  }
  .contact-submit:hover { background: var(--ink); color: var(--paper); }
</style>
